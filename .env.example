# Firebase (optional — defaults exist in src/firebase.js)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin fallback email (until custom claim is set)
VITE_ADMIN_EMAIL=

# showcase = display + quote + WhatsApp (Spark, no Functions)
# full = cart + checkout + coupons (requires Blaze + Cloud Functions)
VITE_COMMERCE_MODE=showcase

# ImgBB image uploads
VITE_IMGBB_KEY=

# Cloud Functions — set in Firebase Console for setAdminClaim bootstrap
# ADMIN_SETUP_SECRET=
