# Firebase (optional — defaults exist in src/firebase.js)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin fallback email (until custom claim is set)
VITE_ADMIN_EMAIL=

# Set to 1 to skip Playwright prerender (e.g. quick local builds)
# SKIP_PRERENDER=1

# showcase = catalog + quote + WhatsApp (no cart)
# full = cart + checkout + coupons (works on Spark via Firestore; Cloud Functions optional on Blaze)
VITE_COMMERCE_MODE=full

# ImgBB image uploads
VITE_IMGBB_KEY=

# Cloudinary (free tier) — PDF course books from admin panel
# 1. cloudinary.com → sign up free
# 2. Settings → Upload → Add upload preset → Signing: Unsigned → Resource type: Raw
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Or paste a Google Drive / direct HTTPS PDF link in admin (no Cloudinary needed)

# Cloud Functions — set in Firebase Console for setAdminClaim bootstrap
# ADMIN_SETUP_SECRET=
